/priv/*.so*
/priv/*.o*
/priv/*.dylib*
# Generated CSS/JS bundle only — priv/static/fonts and priv/static/images
# are committed source assets (self-hosted fonts, icons), same convention
# as code_my_spec.
/priv/static/assets/
/priv/static/cache_manifest.json
*.log
*.zip
*.gz
.DS_Store

# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
todo-*.tar

# If NPM crashes, it generates a log, let's ignore it too.
npm-debug.log

# The directory NPM downloads your dependencies sources to.
/assets/node_modules/
/tmp

# config dir
/.config/*

# C++ targets

# Vendored whisper.cpp — cloned and built by `make` (see Makefile)
/c_src/ear_witness/whisper.cpp/

# Model binaries are too large for git — fetched by `make models/ggml-base.en.bin`
/models/

# Editor
/.vscode/

# CodeMySpec
.code_my_spec/internal/
/diagnostics.jsonl



# Python shit
*.pyc

# Secrets — real values live here, never committed (varlock integration planned)
.env
# Local dev secrets (deploy key etc.) imported by config/dev.exs
config/*.secret.exs
# Claude Code local state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Build artifacts / fetched content — ignore as both dirs AND symlinks
# (a bare `deps` symlink slips past `/deps/`; this caused a self-loop merge).
/deps
/models
/c_src/ear_witness/whisper.cpp

# Virtual-mic driver build output + vendored BlackHole clone (build.sh regenerates)
/native/vmic-macos/build/
/native/vmic-macos/vendor/
