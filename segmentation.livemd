```elixir
scd_values =
  Nx.reshape(result, {num_samples, num_classes})
  |> Nx.backend_transfer()
  |> Nx.diff(axis: 0, order: 1)
  |> Nx.abs()
  |> Nx.reduce_max(axes: [1])
  |> Nx.to_list()
  |> Enum.with_index()
  |> Enum.map(fn {value, index} ->
      %{y: value, x: index * 0.017}    
    end)

VegaLite.new(title: "Speaker Change Detection", width: 800, height: 400)
