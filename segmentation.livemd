|> VegaLite.encode_field(:color, "step", type: :nominal, legend: nil)
|> VegaLite.encode_field(:row, "data", type: :nominal, title: "Data")
|> VegaLite.data_from_values(chart_data)
|> Kino.VegaLite.new()
