```elixir
model = Ortex.load(Path.join([:code.priv_dir(:ear_witness), "models", "segmentation-3.0.onnx"]))

tensor = Nx.from_binary(raw_data, :f32)
input = Nx.reshape(tensor, {1, 1, div(byte_size(raw_data), 4)})
{result} = Ortex.run(model, {input})
{1, num_samples, num_classes} = Nx.shape(result)

speaker_prob_values = 
  Nx.reshape(result, {num_samples, num_classes})
  |> Nx.backend_transfer()
  |> Nx.to_list()
  |> Enum.with_index()
  |> Enum.reduce([], fn {[vad, a, b, c, ab, ac, bc], index}, acc ->
    [
      %{y: a, speaker: "Speaker A", x: index * 0.017},
      %{y: b, speaker: "Speaker B", x: index * 0.017},
      %{y: c, speaker: "Speaker C", x: index * 0.017} | acc      
    ]
  end)

```

```elixir
