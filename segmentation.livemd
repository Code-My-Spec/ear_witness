```elixir
defmodule Conversion do
  def ms_to_bytes(duration, sample_rate) do
    sample_rate * duration * 4 / 1000
  end

  def bytes_to_ms(count_bytes, sample_rate) do
    count_bytes * (1 / 4) * 1000 / sample_rate
  end
end
```

```elixir
sample_rate = 16000
windows = EarWitness.Audio.Windows.new(
  window_size: Conversion.ms_to_bytes(10030, sample_rate) |> trunc(),
  chunk_size: Conversion.ms_to_bytes(17, sample_rate) |> trunc(),
  step_size: Conversion.ms_to_bytes(5015, sample_rate) |> trunc(),
  data: %{scores: []},
  on_step_change: &EarWitness.Audio.SpeakerDiarizationSplitter.on_step_change/1,
  model: model,
  sample_rate: sample_rate,
  max_binaries: 100
)
```

