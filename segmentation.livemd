%{binaries: binaries, data: data, aggregated_data: aggregated_data} = 
  raw_data
  |> Chunks.generate_chunks(1920) 
  |> Enum.reduce(windows, fn chunk, windows -> 
    EarWitness.Audio.Windows.handle_buffer(windows, %{payload: chunk})
  end)

data
```

```elixir
audio_data =
  binaries
  |> Enum.reverse()
  |> Enum.with_index(fn binary, index ->
    Chunks.generate_le_chunks(binary)
    |> Enum.with_index(fn value, inner_index -> 
      %{x: 1.003 * index + (inner_index) / 16000, y: value, step: index, data: "audio"}
    end)
  |> Enum.take_every(10)
  end)
  |> List.flatten()
```

```elixir
aggregated_chart_data = 
  aggregated_data
  |> Enum.reverse()
  |> Enum.map(fn %{start_time: start_time, duration: duration, scd: scd} ->
    Nx.to_list(scd)  
    |> Enum.with_index(fn value, index -> 
      %{x: (start_time + index * duration) / 1000, y: value, data: "aggregated_scd", step: "scd"}
    end)
  end)
  |> List.flatten()
```

```elixir
%{steps_per_frame: steps_per_frame} = windows
scd_data =
  data
  |> Enum.reverse()
  |> Enum.with_index(fn %{scd: scd}, zero_index ->
    index = zero_index + 1
    chart_rows = steps_per_frame + 2
    chart_index = 
      case index > chart_rows do
        false -> index
        true -> index - trunc(index/ chart_rows) * steps_per_frame - 2
      end
    scd
    |> Nx.to_list()
    |> Enum.reverse()
    |> Enum.with_index(fn value, inner_index -> 
      %{
        x: 1.003 * index + inner_index * 0.017, 
        y: value, 
        data: "scd #{to_string(chart_index) |> String.pad_leading(2, "0")}", 
        step: "scd"
      }
    end)
  end)
  |> List.flatten()
```

```elixir
chart_data = audio_data ++ aggregated_chart_data ++ scd_data
  
VegaLite.new(width: 700, height: 60)
|> VegaLite.mark(:line)  
|> VegaLite.encode_field(:x, "x",
    type: :quantitative,
