# Speech Segmentation

## Section

```elixir
defmodule Chunks do
  def generate_le_chunks(samples) when byte_size(samples) >= 4 do
    <<chunk::32-float-little, rest::binary>> = samples
    [chunk | generate_le_chunks(rest)]
  end
  
  def generate_le_chunks(samples) do
    [samples]
  end

  
  def generate_chunks(samples, chunk_size) when byte_size(samples) >= chunk_size do
    <<chunk::binary-size(chunk_size), rest::binary>> = samples
    [chunk | generate_chunks(rest, chunk_size)]
  end

  def generate_chunks(samples, _chunk_size) do
    [samples]
  end
end

raw_data = File.read!("test/fixtures/diarize.raw")
samples = Chunks.generate_le_chunks(raw_data)

Enum.count(samples)
```

```elixir
audio_chart_values = 
  samples 
  |> Enum.with_index(fn value, index -> 
    %{x: index / 16000, y: value}
  end)
```

