```elixir
sample_rate = 16_000
threshold = 0.50
model = Ortex.load(Path.join([:code.priv_dir(:ear_witness), "models", "silero_vad.onnx"]))
init_acc = %{
  h: Nx.broadcast(0.0, {2, 1, 64}),
  c: Nx.broadcast(0.0, {2, 1, 64}),
  data: []
}

vad_values = 
  Chunks.generate_chunks(raw_data, 1920)
  |> Enum.filter(& &1 != "")
  |> Enum.with_index()
  |> Enum.reduce(init_acc, fn {audio, index}, %{h: h, c: c, data: data} -> 
    input = Nx.from_binary(audio, :f32) |> Nx.new_axis(0)
    sr = Nx.tensor(sample_rate)
    {a, b, c} = Ortex.run(model, {input, sr, h, c})

    {output, new_h, new_c} =
      case [Nx.shape(a), Nx.shape(b), Nx.shape(c)] do
        [{1, 1}, {2, 1, 64}, {2, 1, 64}] -> {a, b, c}
        [{2, 1, 64}, {2, 1, 64}, {1, 1}] -> {c, a, b}
        [{2, 1, 64}, {1, 1}, {2, 1, 64}] -> {b, c, a}
      end

    prob = output |> Nx.squeeze() |> Nx.to_number()
    %{h: new_h, c: new_c, data: [%{x: 0.030 * index, y: prob} | data]}
  end)
  |> Map.get(:data)


```

```elixir
VegaLite.new(title: "VAD", width: 800, height: 400)
|> VegaLite.mark(:line)
|> VegaLite.encode_field(:x, "x",
